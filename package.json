{
  "name": "login-service",
  "version": "1.0.0",
  "description": "Welcome to the Login repository.",
  "scripts": {
    "dev:app": "npm run dev --prefix services/user-details-manager/app",
    "build:app": "npm run build --prefix services/user-details-manager/app",
    "build:api": "npm run build:auth-service && npm run build:user-service",
    "build:auth-service": "dotnet build services/authentication-service/api/AuthenticationServiceApi.csproj",
    "build:user-service": "dotnet build services/user-details-manager/api/UserDetailsManagerApi.csproj",
    "test:app": "npm run test --prefix services/user-details-manager/app",
    "test:api": "npm run test:auth-service && npm run test:user-service",
    "test:api:coverage": "npm run test:auth-service:coverage && npm run test:user-service:coverage",
    "test:auth-service": "dotnet test services/authentication-service/api/tests/Authentication.Tests.csproj",
    "test:auth-service:coverage": "dotnet test --collect:'XPlat Code Coverage' services/authentication-service/api/tests/Authentication.Tests.csproj",
    "test:user-service": "dotnet test services/user-details-manager/api/tests/User.Tests.csproj",
    "test:user-service:coverage": "dotnet test --collect:'XPlat Code Coverage' services/user-details-manager/api/tests/User.Tests.csproj",
    "install:app": "npm install --prefix services/user-details-manager/app",
    "start:app": "npm run start --prefix services/user-details-manager/app",
    "start:api": "docker-compose up -d",
    "build": "npm run build:api && npm run build:app",
    "start": "npm run start:api && npm run start:app"
  },
  "author": "Ethan Ely",
  "license": "MIT"
}
